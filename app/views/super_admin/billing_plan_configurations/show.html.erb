<% content_for(:title) { "Plano #{@plan_details[:name]}" } %>

<div class="min-h-screen bg-[rgb(var(--slate-2))] dark:bg-[rgb(var(--slate-1))] p-4 sm:p-6 lg:p-8 font-sans">
  <div class="max-w-screen-2xl mx-auto">
    
    <header class="mb-8">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <h1 class="text-4xl font-bold text-[rgb(var(--slate-12))] dark:text-[rgb(var(--slate-12))]">
            <%= @plan_details[:name] %>
          </h1>
          <p class="mt-3 text-lg text-[rgb(var(--slate-11))] dark:text-[rgb(var(--slate-11))]">
            Detalhes e configurações do plano
          </p>
        </div>
        <div class="flex items-center gap-2">
          <%= link_to super_admin_billing_plan_configurations_path, class: "inline-flex items-center justify-center px-5 py-3 border border-[rgb(var(--border-strong))] rounded-lg text-base font-medium text-[rgb(var(--slate-11))] dark:text-[rgb(var(--slate-11))] bg-white dark:bg-[rgb(var(--slate-4))] hover:bg-[rgb(var(--slate-3))] hover:text-[rgb(var(--slate-12))] dark:hover:bg-[rgb(var(--slate-5))] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[rgb(var(--iris-8))] transition-colors" do %>
            <i class="ri-arrow-left-line mr-2 -ml-1 text-xl"></i>
            Voltar para Planos
          <% end %>
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Informações do Plano -->
      <div class="space-y-8">
        <!-- Detalhes Básicos -->
        <div class="bg-[rgb(var(--solid-1))] dark:bg-[rgb(var(--solid-2))] rounded-xl shadow-md border border-[rgb(var(--border-container))] dark:border-[rgb(var(--border-strong))] overflow-hidden">
          <div class="px-6 py-5 border-b border-[rgb(var(--border-container))] dark:border-[rgb(var(--border-strong))] bg-[rgb(var(--slate-2))] dark:bg-[rgb(var(--slate-3))]">
            <h3 class="text-xl font-bold text-[rgb(var(--slate-12))] dark:text-[rgb(var(--slate-12))] flex items-center">
              <i class="ri-information-line mr-3 text-[rgb(var(--iris-9))] text-2xl"></i>
              Informações do Plano
            </h3>
          </div>
          <div class="p-6">
            <div class="space-y-4">
              <div class="flex justify-between items-center">
                <span class="text-[rgb(var(--slate-11))] dark:text-[rgb(var(--slate-11))]">Nome:</span>
                <span class="font-bold text-[rgb(var(--slate-12))] dark:text-[rgb(var(--slate-12))]"><%= @plan_details[:name] %></span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-[rgb(var(--slate-11))] dark:text-[rgb(var(--slate-11))]">Preço:</span>
                <span class="font-bold text-[rgb(var(--slate-12))] dark:text-[rgb(var(--slate-12))]">R$ <%= @plan_details[:price] %>/mês</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-[rgb(var(--slate-11))] dark:text-[rgb(var(--slate-11))]">Chave:</span>
                <span class="font-mono text-sm bg-[rgb(var(--slate-2))] dark:bg-[rgb(var(--slate-3))] px-2 py-1 rounded text-[rgb(var(--slate-12))] dark:text-[rgb(var(--slate-12))]"><%= @plan_name %></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
